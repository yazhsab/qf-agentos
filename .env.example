# QF-AgentOS configuration (copy to .env; .env is git-ignored).
# All variables are optional and have safe production defaults.
# Full reference: docs/CONFIGURATION.md

# --- Observability ---
QF_LOG_LEVEL=INFO           # DEBUG | INFO | WARNING | ERROR | CRITICAL
QF_LOG_FORMAT=text          # text | json
QF_TRACING_ENABLED=false    # OpenTelemetry spans per agent step (needs the 'otel' extra)

# --- Determinism / numerics ---
QF_DEFAULT_SEED=7
QF_NUMERIC_REL_TOL=1e-6

# --- Simulation guard-rails (the planner abstains rather than exceed these) ---
QF_STATEVECTOR_QUBIT_LIMIT=22
QF_BRUTEFORCE_QUBIT_LIMIT=20

# --- Governance / experiment registry ---
QF_EVIDENCE_DIR=evidence
QF_REGISTRY_BACKEND=file             # file | mlflow | postgres
# QF_MLFLOW_TRACKING_URI=http://mlflow:5000            # needs the 'mlflow' extra
# QF_MLFLOW_EXPERIMENT=qf-agentos
# QF_POSTGRES_DSN=postgresql+psycopg://user:pass@host/db   # needs the 'postgres' extra

# --- REST API ---
QF_API_MAX_INVENTORY=2000            # reject larger problems over the API (all families) -> 413
# QF_API_KEYS=key-a,key-b            # comma-separated; if set, the solve endpoints + registries
                                     # require X-API-Key. Empty = OPEN (dev only; logs a warning).
QF_API_RATE_LIMIT_PER_MINUTE=60      # per-client limit on the solve endpoints
QF_API_JOB_WORKERS=2                 # concurrent async (/jobs) solve workers
QF_API_MAX_JOBS=256                  # retained job records (LRU)

# --- Backend credentials (secrets: never commit; L3 + approval also required) ---
# Real hardware needs ALL of: a token here, qpu_backend: ibm|dwave in the spec,
# autonomy_level: L3, max_qpu_budget_usd, and --approve.  See docs/real-qpu.md
# QF_IBM_TOKEN=
# QF_IBM_CHANNEL=ibm_quantum_platform  # or ibm_cloud (the legacy 'ibm_quantum' channel was retired)
# QF_IBM_INSTANCE=                     # instance CRN / hub-group-project (optional on the Open plan)
# QF_IBM_BACKEND=                      # pin a device; else least-busy
# QF_DWAVE_TOKEN=
