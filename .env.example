# QF-AgentOS configuration (copy to .env; .env is git-ignored).
# All variables are optional and have safe production defaults.

# --- Observability ---
QF_LOG_LEVEL=INFO           # DEBUG | INFO | WARNING | ERROR | CRITICAL
QF_LOG_FORMAT=text          # text | json
QF_TRACING_ENABLED=false    # OpenTelemetry spans per agent step (needs the 'otel' extra)

# --- Determinism / numerics ---
QF_DEFAULT_SEED=7
QF_NUMERIC_REL_TOL=1e-6

# --- Simulation guard-rails ---
QF_STATEVECTOR_QUBIT_LIMIT=22
QF_BRUTEFORCE_QUBIT_LIMIT=20

# --- Governance ---
QF_EVIDENCE_DIR=evidence

# --- REST API ---
QF_API_MAX_INVENTORY=2000            # reject larger problems over the sync API
# QF_API_KEYS=key-a,key-b            # comma-separated; if set, /solve and /runs require X-API-Key. Empty = open (dev).
QF_API_RATE_LIMIT_PER_MINUTE=60      # per-client /solve rate limit

# --- Backend credentials (leave blank unless running real hardware; L3-gated) ---
# QF_IBM_TOKEN=
# QF_IBM_INSTANCE=
# QF_IBM_BACKEND=
# QF_DWAVE_TOKEN=
